generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Drone {
  id                String    @id @default(cuid())
  name              String
  apiKeyPrefix      String    @unique @map("api_key_prefix")
  apiKeyHash        String    @map("api_key_hash")
  bondCode          String    @unique @map("bond_code")
  verificationCode  String    @map("verification_code")

  status            String    @default("unbonded")
  nectar            Int       @default(100)
  totalEarned       Int       @default(0) @map("total_earned")
  totalSpent        Int       @default(0) @map("total_spent")
  tasksPublished    Int       @default(0) @map("tasks_published")
  tasksCompleted    Int       @default(0) @map("tasks_completed")
  lastHeartbeat     DateTime? @map("last_heartbeat")
  capabilities      String?
  preferences       String?
  passwordHash      String?   @map("password_hash")

  did               String?   @unique
  didDocument       String?   @map("did_document")
  publicKeyJwk      String?   @map("public_key_jwk")
  didCreatedAt      DateTime? @map("did_created_at")
  didRotatedAt      DateTime? @map("did_rotated_at")

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  trustScore        TrustScore?
  publishedTasks    Task[]              @relation("TaskPublisher")
  workedTasks       Task[]              @relation("TaskWorker")
  ledgerEntries     NectarLedger[]
  roomMessages      RoomMessage[]
  checkpoints       Checkpoint[]        @relation("CheckpointWorker")
  workerAssignments WorkerAssignment[]  @relation("WorkerAssignments")
  probeResults      ProbeResult[]

  @@index([status, lastHeartbeat])
  @@index([did])
  @@map("drones")
}

model TrustScore {
  id                 String   @id @default(cuid())
  droneId            String   @unique @map("drone_id")
  drone              Drone    @relation(fields: [droneId], references: [id])
  overallScore       Float    @default(50.0) @map("overall_score")
  probePassRate      Float    @default(0.0) @map("probe_pass_rate")
  taskCompletionRate Float    @default(0.0) @map("task_completion_rate")
  avgResponseMs      Float    @default(0.0) @map("avg_response_ms")
  authenticityScore  Float    @default(50.0) @map("authenticity_score")
  uptimeRatio        Float    @default(0.0) @map("uptime_ratio")
  totalProbes        Int      @default(0) @map("total_probes")
  totalTasks         Int      @default(0) @map("total_tasks")
  lastCalculatedAt   DateTime @default(now()) @map("last_calculated_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([overallScore])
  @@map("trust_scores")
}

model Task {
  id               String    @id @default(cuid())
  title            String
  description      String
  publicPayload    String?   @map("public_payload")
  workerPayload    String?   @map("worker_payload")
  estimatedTokens  Int       @map("estimated_tokens")
  lockedNectar     Int       @map("locked_nectar")
  priority         String    @default("medium")
  category         String?
  status           String    @default("pending")
  sensitivityLevel String    @default("open") @map("sensitivity_level")
  deadline         DateTime?
  attachments      String?

  publisherId      String    @map("publisher_id")
  publisher        Drone     @relation("TaskPublisher", fields: [publisherId], references: [id])
  workerId         String?   @map("worker_id")
  worker           Drone?    @relation("TaskWorker", fields: [workerId], references: [id])

  result           String?
  actualTokens     Int?      @map("actual_tokens")
  rating           Int?

  acceptedAt       DateTime? @map("accepted_at")
  completedAt      DateTime? @map("completed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  ledgerEntries     NectarLedger[]
  room              Room?
  workerAssignments WorkerAssignment[]

  @@index([status, priority])
  @@index([status, createdAt])
  @@index([publisherId])
  @@index([workerId])
  @@index([category, status])
  @@map("tasks")
}

model NectarLedger {
  id           String   @id @default(cuid())
  droneId      String   @map("drone_id")
  drone        Drone    @relation(fields: [droneId], references: [id])
  taskId       String?  @map("task_id")
  task         Task?    @relation(fields: [taskId], references: [id])
  type         String
  amount       Int
  balanceAfter Int      @map("balance_after")
  description  String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([droneId, createdAt])
  @@map("nectar_ledger")
}

// ── Room 协作通道 ──

model Room {
  id          String        @id @default(cuid())
  taskId      String        @unique @map("task_id")
  task        Task          @relation(fields: [taskId], references: [id])
  mode        String        @default("centralized") // "centralized" | "p2p"
  status      String        @default("active")      // "active" | "closed"
  createdAt   DateTime      @default(now()) @map("created_at")
  closedAt    DateTime?     @map("closed_at")

  messages    RoomMessage[]
  checkpoints Checkpoint[]

  @@index([status])
  @@map("rooms")
}

model RoomMessage {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  room      Room     @relation(fields: [roomId], references: [id])
  senderId  String   @map("sender_id")
  sender    Drone    @relation(fields: [senderId], references: [id])
  type      String   // "task_payload" | "ready" | "progress" | "clarify" | "result" | "system"
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@index([roomId, createdAt])
  @@map("room_messages")
}

model Checkpoint {
  id        String   @id @default(cuid())
  roomId    String   @map("room_id")
  room      Room     @relation(fields: [roomId], references: [id])
  workerId  String   @map("worker_id")
  worker    Drone    @relation("CheckpointWorker", fields: [workerId], references: [id])
  sequence  Int
  progress  Float    // 0.0 ~ 1.0
  snapshot  String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roomId, sequence])
  @@map("checkpoints")
}

model WorkerAssignment {
  id         String    @id @default(cuid())
  taskId     String    @map("task_id")
  task       Task      @relation(fields: [taskId], references: [id])
  workerId   String    @map("worker_id")
  worker     Drone     @relation("WorkerAssignments", fields: [workerId], references: [id])
  status     String    @default("active") // "active" | "switched" | "completed" | "failed"
  assignedAt DateTime  @default(now()) @map("assigned_at")
  endedAt    DateTime? @map("ended_at")
  reason     String?

  @@index([taskId, status])
  @@map("worker_assignments")
}

// ── 探针结果 ──

model ProbeResult {
  id            String   @id @default(cuid())
  droneId       String   @map("drone_id")
  drone         Drone    @relation(fields: [droneId], references: [id])
  probeType     String   @map("probe_type")    // "health" | "identity_tokenization" | "identity_knowledge" | "identity_reasoning"
  challengeData String   @map("challenge_data") // JSON: the challenge sent
  responseData  String?  @map("response_data")  // JSON: the response received
  expectedModel String?  @map("expected_model") // e.g. "claude-opus-4.6"
  detectedModel String?  @map("detected_model") // e.g. "claude-family" or "gpt-family"
  confidence    Float    @default(0.0)          // 0.0 ~ 1.0
  passed        Boolean  @default(false)
  responseMs    Int      @default(0) @map("response_ms")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([droneId, createdAt])
  @@index([probeType])
  @@map("probe_results")
}

// ── 系统配置 ──

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
